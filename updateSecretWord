def updateSecretWord(w, sw, c):
    word = ""
    for i in range(len(w)):
        if w[i] == c:
            word += c
        else:
            word += sw[i]
    return word


print(updateSecretWord("hello", "_____", "o"))
print(updateSecretWord("hello", "____o", "o"))
print(updateSecretWord("hello", "____o", "b"))
